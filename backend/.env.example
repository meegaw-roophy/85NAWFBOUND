# --- VEKTRA Backend Environment Variables ---
# Copy this file to .env and fill in real values before running.

# REQUIRED: A strong random secret for signing JWTs.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Database connection string (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db:5432/vektra

# Optional: Anthropic API key for AI-powered reports
CLAUDE_API_KEY=

# Optional: Stripe secret key for payment processing
STRIPE_API_KEY=

# Comma-separated list of allowed CORS origins
ALLOWED_CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
