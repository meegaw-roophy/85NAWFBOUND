# Backend Environment Variables
# Copy this to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@db:5432/vektra
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI (optional - fallback summary used if not set)
CLAUDE_API_KEY=

# Payments (optional - endpoints return "not configured" if unset)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS (comma-separated origins)
ALLOWED_CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
