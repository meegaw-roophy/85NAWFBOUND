# --- Docker Compose Environment Variables ---
# Copy this file to .env before running `docker compose up`

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=vektra

# Backend
SECRET_KEY=CHANGE_ME_GENERATE_WITH_python_c_import_secrets_print_secrets_token_urlsafe_32
CLAUDE_API_KEY=
STRIPE_API_KEY=
ALLOWED_CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Frontend (Django)
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
